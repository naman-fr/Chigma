    },
    {
      "title": "Total Requests",
      "type": "stat",
      "datasource": "Prometheus",
      "targets": [{"expr": "sum(chigma_requests_total)"}],
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 8}
    },
    {
      "title": "Error Rate",
      "type": "stat",
      "datasource": "Prometheus",
      "targets": [{"expr": "sum(rate(chigma_requests_total{status=~\"5..\"}[5m])) / sum(rate(chigma_requests_total[5m]))"}],
