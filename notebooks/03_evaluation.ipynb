   "source": [
    "from src.detection.evaluate import Evaluator\n",
    "from pathlib import Path\n",
    "\n",
    "model_path = '../models/checkpoints/fd-yolo11/weights/best.pt'\n",
    "if Path(model_path).exists():\n",
    "    evaluator = Evaluator(model_path, '../configs/dataset.yaml')\n",
    "    results = evaluator.evaluate_ultralytics()\n",
    "    evaluator.benchmark_speed()\n",
    "    evaluator.compare_baseline()\n",
    "else:\n",
    "    print(f\"Model checkpoint not found at {model_path}. Train the model first.\")"
   ]
